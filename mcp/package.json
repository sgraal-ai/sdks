{
  "name": "@sgraal/mcp",
  "version": "0.2.1",
  "description": "AI agent memory governance MCP server — preflight validation before every action. Works with Claude Desktop, LangGraph, and any MCP-compatible client.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "sgraal-mcp": "dist/server.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./server": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "sgraal",
    "mcp",
    "ai",
    "memory",
    "governance",
    "claude",
    "langgraph",
    "memory-safety",
    "hallucination",
    "preflight",
    "ai-safety",
    "agent-memory",
    "model-context-protocol",
    "claude-desktop",
    "ai-agents",
    "llm"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sgraal-ai/sdks"
  },
  "homepage": "https://sgraal.com",
  "license": "Apache-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": ">=1.0.0 <2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^22.0.0"
  }
}
